# Leave this as /api for local development and same-domain deploys.
# For a separate Vercel frontend, set it to https://your-render-service.onrender.com/api
VITE_API_BASE_URL=/api
# Optional alias if your hosting provider already uses this variable name.
VITE_API_URL=
VITE_BACKEND_TARGET=http://127.0.0.1:5000
VITE_CSRF_COOKIE_NAME=wesplit_csrf
VITE_SHARE_BASE_URL=
